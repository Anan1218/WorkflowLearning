# Model providers. Instructor routes by the "provider/model" prefix and reads the
# matching key automatically (the LiteLLM convention it's built on). To use a
# different model: drop its key in below and change the MODEL string in
# src/extract.py (e.g. "openai/gpt-5.1"). Nothing else changes.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# MISTRAL_API_KEY=
# GROQ_API_KEY=

# Langfuse Cloud (get keys at https://cloud.langfuse.com -> project settings)
# For a real RLI/PII deployment, self-host Langfuse and point LANGFUSE_HOST at it.
# That is a deployment-time change only - no code change (the OTel payoff).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com

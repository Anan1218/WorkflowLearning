# Model provider (Instructor talks to it via from_provider)
ANTHROPIC_API_KEY=

# Langfuse Cloud (get keys at https://cloud.langfuse.com -> project settings)
# For a real RLI/PII deployment, self-host Langfuse and point LANGFUSE_HOST at it.
# That is a deployment-time change only - no code change (the OTel payoff).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com
